# --- HTTP ---
# Cổng Core API (mặc định 3000 nếu không set).
PORT=3000

# --- Dữ liệu & hàng đợi (khớp `docker-compose.yml` ở root repo) ---
DATABASE_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge
REDIS_URL=redis://localhost:6379

# --- JWT (bắt buộc khi chạy AuthModule) ---
JWT_SECRET=change-me-in-production
# Thời hạn token (giây). Mặc định trong code: 604800 (7 ngày).
# JWT_EXPIRES_IN=3600

# --- Swagger OpenAPI ---
# Tắt UI: SWAGGER_ENABLED=0. Tự tắt khi NODE_ENV=production.
# SWAGGER_ENABLED=1
# NODE_ENV=development

# --- Tuỳ chọn / tương lai (chưa đọc trong code hiện tại; bỏ comment khi tích hợp) ---
# APP_ENV=dev
# DIRECT_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# CLOUDINARY_URL=
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=codejudge
